generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== v0.2: 扩展后的角色枚举 =====
// admin: 应用管理员（系统级）
// creator: 族谱创建者（用户创建族谱时自动获得）
// collaborator: 族谱协作者（需申请审批）
// editor: [已废弃，保留兼容旧数据] → 迁移为 collaborator
// viewer: 普通查看者
enum Role {
  admin
  creator
  collaborator
  editor
  viewer
}

enum RelationType {
  parent_of
  spouse_of
}

enum OcrTaskStatus {
  pending
  running
  succeeded
  failed
  reviewed
}

enum ExportTaskStatus {
  pending
  running
  succeeded
  failed
}

// ===== v0.2 新增枚举 =====

enum AccessRequestStatus {
  pending
  approved
  rejected
}

enum AccessRequestType {
  collaborator
  viewer
}

enum EditRequestStatus {
  pending
  approved
  rejected
  revision_needed
}

// ===== 数据模型 =====

model Family {
  id          String           @id @default(cuid())
  name        String
  code        String           @unique
  creatorId   String?          // v0.2: 创建者用户ID
  accessLevel String           @default("approval_required") // v0.2: "public" | "approval_required"
  createdAt   DateTime         @default(now())
  users       FamilyUserRole[]
  members     Member[]
  relations   Relationship[]
  sources     SourceDocument[]
  visibility  VisibilityPolicy[]
  ocrTasks    OcrTask[]
  exportTasks ExportTask[]
  auditLogs   AuditLog[]
}

model User {
  id           String           @id @default(cuid())
  username     String           @unique
  passwordHash String
  status       String           @default("active")
  familyRoles  FamilyUserRole[]
  auditLogs    AuditLog[]
}

model FamilyUserRole {
  id        String   @id @default(cuid())
  familyId  String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
}

model Member {
  id         String    @id @default(uuid())
  familyId   String
  name       String
  generation Int?
  alias      String?
  gender     String?
  isLiving   Boolean   @default(true)
  notes      String?
  createdAt  DateTime  @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, name])
  @@index([familyId, generation])
}

model Relationship {
  id           String       @id @default(cuid())
  familyId     String
  fromMemberId String
  toMemberId   String
  type         RelationType
  createdAt    DateTime     @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, fromMemberId, toMemberId, type])
}

model VisibilityPolicy {
  id        String   @id @default(cuid())
  familyId  String
  role      Role
  fieldName String
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, role])
}

model SourceDocument {
  id         String   @id @default(cuid())
  familyId   String
  objectKey  String
  filename   String
  mimeType   String
  uploadedAt DateTime @default(now())

  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  ocrTasks OcrTask[]
}

model OcrTask {
  id               String        @id @default(cuid())
  familyId         String
  sourceDocumentId String
  status           OcrTaskStatus @default(pending)
  errorMessage     String?
  createdAt        DateTime      @default(now())

  family         Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  candidates     OcrCandidate[]

  @@index([familyId, status, createdAt])
}

model OcrCandidate {
  id         String   @id @default(cuid())
  ocrTaskId  String
  fieldName  String
  fieldValue String
  confidence Float
  bboxJson   String?

  task OcrTask @relation(fields: [ocrTaskId], references: [id], onDelete: Cascade)
}

model ExportTask {
  id          String           @id @default(cuid())
  familyId    String
  type        String           @default("quick_table") // v0.2: "quick_table" | "drop_line" | "biography"
  status      ExportTaskStatus @default(pending)
  objectKey   String?
  requestedBy String?
  createdAt   DateTime         @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  familyId    String
  userId      String?
  action      String
  targetType  String
  targetId    String?
  metadataJson String?
  createdAt   DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([familyId, targetType, targetId])
}

// ===== v0.2 新增模型 =====

// 协作者/查看者申请记录
model AccessRequest {
  id          String              @id @default(cuid())
  familyId    String
  userId      String              // 申请者
  type        AccessRequestType   // 申请成为协作者或查看者
  status      AccessRequestStatus @default(pending)
  reason      String?             // 申请理由
  reviewerId  String?             // 审批人ID
  reviewNote  String?             // 审批备注
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([familyId, status])
  @@index([userId])
}

// 协作者修改审批记录
model EditRequest {
  id            String            @id @default(cuid())
  familyId      String
  userId        String            // 提交修改的协作者
  editType      String            // member_create/member_update/member_delete/relation_create/relation_delete
  editPayload   String            // JSON格式的修改内容
  reason        String?           // 修改原因
  status        EditRequestStatus @default(pending)
  reviewerId    String?
  reviewNote    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([familyId, status])
  @@index([userId])
}

// 站内通知
model Notification {
  id          String   @id @default(cuid())
  userId      String   // 接收通知的用户
  type        String   // access_request/access_approved/access_rejected/edit_request/edit_approved/edit_rejected
  title       String
  content     String?
  relatedId   String?  // 关联的请求ID
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
